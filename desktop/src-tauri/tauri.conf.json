{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Science Proxy",
  "version": "0.3.6",
  "identifier": "com.csp.menubar",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Claude Science Proxy",
        "width": 340,
        "height": 700,
        "minWidth": 300,
        "minHeight": 560,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": true,
        "center": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../proxy/anthropic_compat.py": "proxy/anthropic_compat.py",
      "../../proxy/csp_proxy.py": "proxy/csp_proxy.py",
      "../../proxy/dsml_shim.py": "proxy/dsml_shim.py",
      "../../proxy/http_transport.py": "proxy/http_transport.py",
      "../../proxy/model_discovery.py": "proxy/model_discovery.py",
      "../../proxy/model_registry.py": "proxy/model_registry.py",
      "../../proxy/model_sort.py": "proxy/model_sort.py",
      "../../proxy/openai_chat_compat.py": "proxy/openai_chat_compat.py",
      "../../proxy/provider_policy.py": "proxy/provider_policy.py",
      "../../proxy/responses_compat.py": "proxy/responses_compat.py",
      "../../scripts/doctor.sh": "scripts/doctor.sh",
      "../../scripts/launch-virtual-sandbox.sh": "scripts/launch-virtual-sandbox.sh",
      "../../scripts/stop-science-sandbox.sh": "scripts/stop-science-sandbox.sh",
      "../../scripts/verify-proxy.sh": "scripts/verify-proxy.sh"
    },
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
