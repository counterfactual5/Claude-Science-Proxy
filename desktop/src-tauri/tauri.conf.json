{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CSSwitch",
  "version": "0.3.6",
  "identifier": "com.csswitch.menubar",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "CSSwitch",
        "width": 420,
        "height": 700,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": true,
        "center": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../proxy/anthropic_compat.py": "proxy/anthropic_compat.py",
      "../../proxy/csswitch_proxy.py": "proxy/csswitch_proxy.py",
      "../../proxy/dsml_shim.py": "proxy/dsml_shim.py",
      "../../proxy/provider_policy.py": "proxy/provider_policy.py",
      "../../proxy/qwen_proxy.py": "proxy/qwen_proxy.py",
      "../../scripts/doctor.sh": "scripts/doctor.sh",
      "../../scripts/launch-virtual-sandbox.sh": "scripts/launch-virtual-sandbox.sh",
      "../../scripts/stop-science-sandbox.sh": "scripts/stop-science-sandbox.sh"
    },
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
