{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CSSwitch",
  "version": "0.2.0",
  "identifier": "com.csswitch.menubar",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "CSSwitch",
        "width": 340,
        "height": 560,
        "minWidth": 320,
        "minHeight": 520,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": true,
        "center": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../proxy": "proxy",
      "../../scripts": "scripts"
    },
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
