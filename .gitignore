# 沙箱运行时（大文件、克隆资产、可能含新登录凭证）
.sandbox/

# 运行产物
proxy/proxy.log
proxy/proxy.stdout
*.pyc
__pycache__/

# 绝不入库任何密钥
*.env
.env
*secret*
*token*

# Rust / Tauri 构建产物
target/
**/target/

# 前端依赖与构建产物（Tauri / py2app）
node_modules/
dist/
build/

# macOS 与工作区杂物
.DS_Store
.superpowers/
.vscode/

# 本地开发工作流文档（brainstorm→spec→plan），不上传公开仓库
docs/superpowers/

# 内部调查/取证文档（base/知识库），不发布；目录由维护脚本运行时 mkdir
findings/

# Local version comparison binaries; never commit.
.science-binaries/

# Local scratch files and runtime intermediates.
scratchpad/

# Local Claude Code session config.
.claude/

# Local agent / test / IDE caches (never publish)
.playwright-cli/
.pytest_cache/
.ruff_cache/
.workbuddy/

# Local seed files.
.seed
